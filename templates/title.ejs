<div id='pad_title' class='flex_title'>
  <div id='title'><h1><a href="" data-l10n-id="pad.loading">Loading...</a></h1></div>
  <input id='input_title'>
  <div id='edit_title' class='acl-write buttonicon buttonicon-pencil-alt'></div>
  <div id='save_title'><button class="btn btn-primary">OK</button></div>
</div>

<style type="text/css">
  /* Bar height kept tight so the body-level title doesn't eat enough of the
     editor viewport to break etherpad's auto-scroll on Enter (the bar pushes
     the iframe down without the editor's scroll calculation accounting for
     it — see ep_set_title_on_pad CI history vs etherpad-lite #7611). */
  #pad_title {
    flex-direction: row;
    align-items: center;
    border-bottom: 1px solid #ccc;
    margin: 0 !important;
    padding: 0 10px;
    height: 22px;
    box-sizing: border-box;
    line-height: 21px;
  }
  #input_title{
    display:none;
    flex: 1 auto;
    padding: 2px 8px !important;
    height: 18px;
    box-sizing: border-box;
  }
  #title{
    line-height: 21px;
    max-width: calc(100% - 30px);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  #title h1 a{
    text-decoration:none;
  }
  #title h1{
    margin: 0;
    padding: 0;
    font-size: 13px;
    line-height: 21px;
    font-weight: 600;
  }
  #edit_title{
    padding: 0;
    margin-left: 10px;
    cursor:pointer;
    display:none;
    line-height: 21px;
  }
  #save_title{
    display:none;
    cursor:pointer;
    margin-left:8px;
    line-height: 21px;
  }
  #save_title button{
    margin-right: 0 !important;
  }
  @media print{
    #edit_title, #save_title{
      display:none;
    }
  }
  @media (max-width: 720px){
    #pad_title{
      display:none !important;
    }
  }
  .display_important {
    display:none !important;
  }
  .flex_title{
    display: flex !important;
  }
</style>
